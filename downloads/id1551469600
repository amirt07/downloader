oup":null,"seeAllAction":null,"footerTitle":null,"footerAction":null,"eyebrow":null,"eyebrowArtwork":null,"footerStyle":null,"titleArtwork":null,"subtitle":null,"isHorizontal":false,"isHidden":false,"rowsPerColumn":null,"background":{"type":"none"},"contentsMetadata":{"type":"none"},"isPersonalized":false,"shouldFilterApps":false,"id":"writeAReviewProductReviewAction"},"mostRecentVersion":{"$kind":"Shelf","impressionMetrics":{"fields":{"id":"24","name":"What’s New","impressionType":"versionHistory","idType":"sequential","impressionIndex":2}},"contentType":"titledParagraph","marker":null,"items":[{"$kind":"TitledParagraph","text":"This update from Apple will improve the functionality of this app. No new features are included.\n\nFluffyChat 2.5.1 introduces a new homeserver picker for onboarding,\nbetter image compression performance and several smaller new features,\ndesign adjustments and bug fixes.","style":"overview","wantsCollapsedNewlines":true,"primarySubtitle":"Version v2.5.1","secondarySubtitle":"Sun Mar 29 2026 01:13:54 GMT+0000 (Coordinated Universal Time)"}],"url":null,"mergeWhenFetched":false,"fetchStrategy":"onPageLoad","batchGroup":null,"seeAllAction":{"title":"Version History","presentationStyle":[],"actionMetrics":{"$kind":"ActionMetrics","data":[{"fields":{"location":[{"locationPosition":2,"locationType":"button","name":"Version History"}],"actionType":"navigate","target":"button_See All","eventType":"click","targetType":"button","targetId":"See All","platformContext":"iphone","alt_ab2_data":"[]"},"includingFields":["impressionsSnapshot","pageFields","contentRestrictionReasons"],"excludingFields":["amsMetricsID"],"topic":"xp_amp_appstore_unidentified","shouldFlush":false}],"custom":{}},"$kind":"flowAction","actionClass":"FlowAction","page":"versionHistory","pageData":{"shelves":[{"$kind":"Shelf","impressionMetrics":null,"contentType":"titledParagraph","marker":null,"items":[{"$kind":"TitledParagraph","text":"This update from Apple will improve the functionality of this app. No new features are included.\n\nFluffyChat 2.5.1 introduces a new homeserver picker for onboarding,\nbetter image compression performance and several smaller new features,\ndesign adjustments and bug fixes.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.5.1","secondarySubtitle":"Sun Mar 29 2026 01:13:54 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat 2.4.0 adds a new improved GUI for managing stickers with tutorials how to\neasily add your own sticker packs.\nIt also improves the search and image gallery in chats, especially encrypted chats.\nBesides that this update comes with a lot of fixes and improvements under the hood.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.4.0","secondarySubtitle":"Wed Jan 21 2026 18:38:19 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat 2.3.0 fixed a major performance leak and introduces two new features: polls and threads.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.3.0","secondarySubtitle":"Sun Nov 16 2025 20:15:33 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat 2.2.0 introduces a new UX for spaces and adds support for restricted\njoin rules.\n\nThe app also now has a new design for recording voice messages including a\npause button.\n\nYou also now see the progress when downloading files.\n\nThe notifications are now localized. Stay tuned for more improvements on Push\nnotifications in the next releases!\n \nBesides that this release brings a ton of bug fixes and performance improvements and\nof course updated translations. Big thanks to all the volunteers who have helped on weblate!","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.2.0","secondarySubtitle":"Thu Oct 30 2025 21:36:23 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Small bug fixes and performance improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.1.1","secondarySubtitle":"Sun Aug 31 2025 23:56:33 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat 2.1.0 brings support for room version 12 and a lot of bugfixes, updated translations and performance improvements. Also chat state events are now collapsed by default.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.1.0","secondarySubtitle":"Mon Aug 18 2025 07:58:49 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat 2.0.0 now uses the Vodozemac encryption library and brings bugfixes and performance improvements, together with an improved user experience when interacting with messages.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v2.0.0","secondarySubtitle":"Sat Jun 21 2025 23:03:03 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Bugfixes and stability improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.27.0","secondarySubtitle":"Fri Jun 06 2025 15:09:59 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Bug fixes and stability improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.26.1","secondarySubtitle":"Sun May 11 2025 08:19:52 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"New camera button for the chat view, lot's of bug fixes and stability improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.26.0","secondarySubtitle":"Mon Apr 28 2025 11:22:35 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"+ New chat bubble design\n+ New setting for key sharing under settings > security\n+ Improved push rule settings\n+ Better rendering of html messages\n+ Bugfixes and performance improvements","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.25.0","secondarySubtitle":"Thu Feb 20 2025 23:31:07 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Bugfixes and performance improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.24.0","secondarySubtitle":"Mon Feb 03 2025 18:30:25 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Refreshed design and various bugfixes and performance improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.23.0","secondarySubtitle":"Mon Dec 02 2024 17:52:48 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"FluffyChat v1.22.0 brings a new design for spaces, replaces the bottom navigation bar with filter chips and makes it finally possible to play ogg audio messages on iOS. A lot of other fixes and improvements have also been added to this release.\n\nFluffyChat also now uses the new authenticated media endpoints if the server supports Matrix v1.11 or\nmentions the msc with the key org.matrix.msc3916.stable in the unstable_features.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.22.0","secondarySubtitle":"Sun Sep 01 2024 03:41:56 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Bugfixes and stability improvements.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.21.2","secondarySubtitle":"Mon Jul 15 2024 07:33:14 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Hotfix for sometimes not possible to unlock the app when using the screen lock feature.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.21.1","secondarySubtitle":"Mon Jun 17 2024 10:11:37 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","text":"Bugfixes, performance improvements and a new search feature in the chats.","style":"detail","wantsCollapsedNewlines":true,"primarySubtitle":"v1.21.0","secondarySubtitle":"Sat Jun 01 2024 19:34:47 GMT+0000 (Coordinated Universal Time)"},{"$kind":"TitledParagraph","